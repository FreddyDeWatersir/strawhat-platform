# Shared login password for your friend (required)
SITE_PASSWORD=change-me-to-a-strong-password

# Anthropic — server only, never use NEXT_PUBLIC_ prefix
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (defaults: Haiku for extraction, Sonnet for chat)
# ANTHROPIC_MODEL_EXTRACT=claude-3-5-haiku-20241022
# ANTHROPIC_MODEL_CHAT=claude-sonnet-4-20250514

# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
