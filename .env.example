# Shared login password for your friend (required)
SITE_PASSWORD=change-me-to-a-strong-password

# Anthropic — server only, never use NEXT_PUBLIC_ prefix
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI — embeddings for hybrid search (server only)
# https://dash.voyageai.com/
VOYAGE_API_KEY=pa-...
# Optional: defaults to voyage-4-lite
# VOYAGE_EMBEDDING_MODEL=voyage-4-lite

# Optional model overrides (defaults: Haiku for extraction, Sonnet for chat)
# ANTHROPIC_MODEL_EXTRACT=claude-haiku-4-5
# ANTHROPIC_MODEL_CHAT=claude-sonnet-4-6

# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Wholesale watch — Discord alerts for TCG Wholesale HQ restocks/price changes
# Create a webhook in your Discord server: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Cron auth — Vercel sends Authorization: Bearer <CRON_SECRET> on scheduled runs
# Also used by /api/cron/wholesale manual triggers via x-cron-secret header
CRON_SECRET=change-me-to-a-long-random-string
